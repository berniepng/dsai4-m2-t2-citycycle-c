*.csv
!data/mock/*.csv

# ── OS & IDE ──────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~

# ── Node ──────────────────────────────────────────────────
node_modules/
npm-debug.log*

